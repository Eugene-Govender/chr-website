{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "build": {
      "inputs": [
        { "step": "install" },
        { "local": true, "include": ["."], "exclude": ["node_modules"] }
      ],
      "commands": ["npm run build"]
    }
  },
  "deploy": {
    "startCommand": "npm run start"
  }
}
